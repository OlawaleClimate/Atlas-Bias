{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bias-atlas.local/schema/bias_record_schema.json",
  "title": "Climate Model Bias Record",
  "type": "object",
  "required": [
    "id",
    "name",
    "version",
    "last_updated",
    "category",
    "region",
    "season",
    "affected_variables",
    "description",
    "persistence",
    "cmip_history",
    "severity_by_model",
    "implicated_params",
    "fix_attempts",
    "cascade_links",
    "disputed_mechanisms",
    "citations",
    "feedback_history",
    "changelog"
  ],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "last_updated": { "type": "string", "format": "date" },
    "category": {
      "type": "string",
      "enum": ["precipitation", "temperature", "circulation", "clouds", "ocean", "land", "sea_ice"]
    },
    "region": { "type": "string", "minLength": 1 },
    "season": { "type": "string", "minLength": 1 },
    "affected_variables": {
      "type": "array",
      "items": { "type": "string" }
    },
    "description": { "type": "string", "minLength": 1 },
    "persistence": {
      "type": "string",
      "enum": ["longstanding", "improved", "resolved", "introduced"]
    },
    "cmip_history": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["generation", "severity", "notes"],
        "properties": {
          "generation": { "type": "string", "enum": ["CMIP3", "CMIP5", "CMIP6", "CMIP7"] },
          "severity": { "type": "string", "enum": ["strong", "moderate", "weak", "absent"] },
          "notes": { "type": "string" }
        }
      }
    },
    "severity_by_model": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["severity", "direction", "source"],
        "properties": {
          "severity": { "type": "string", "enum": ["strong", "moderate", "weak", "absent"] },
          "direction": { "type": "string" },
          "source": { "type": "string" }
        }
      }
    },
    "implicated_params": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["subsystem", "parameter", "role", "type", "evidence"],
        "properties": {
          "subsystem": { "type": "string" },
          "parameter": { "type": "string" },
          "role": { "type": "string" },
          "type": { "type": "string", "enum": ["primary", "secondary"] },
          "evidence": { "type": "string" }
        }
      }
    },
    "fix_attempts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["model", "version", "change", "mechanism", "outcome", "side_effects", "reference"],
        "properties": {
          "model": { "type": "string" },
          "version": { "type": "string" },
          "change": { "type": "string" },
          "mechanism": { "type": "string" },
          "outcome": { "type": "string", "enum": ["success", "partial", "backfired", "unknown"] },
          "side_effects": { "type": "string" },
          "reference": { "type": "string" }
        }
      }
    },
    "cascade_links": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["target_bias", "relationship", "evidence", "confidence"],
        "properties": {
          "target_bias": { "type": "string" },
          "relationship": {
            "type": "string",
            "enum": ["causes", "amplifies", "masks", "triggered_by", "resolved_by"]
          },
          "evidence": { "type": "string" },
          "confidence": { "type": "string", "enum": ["high", "medium", "low"] }
        }
      }
    },
    "disputed_mechanisms": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["claim", "view_a", "view_b", "status"],
        "properties": {
          "claim": { "type": "string" },
          "view_a": { "type": "object" },
          "view_b": { "type": "object" },
          "status": { "type": "string" }
        }
      }
    },
    "citations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["authors", "year", "journal", "doi", "relevance"],
        "properties": {
          "authors": { "type": "string" },
          "year": { "type": "integer" },
          "journal": { "type": "string" },
          "doi": { "type": "string" },
          "relevance": { "type": "string" }
        }
      }
    },
    "feedback_history": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["issue_number", "type", "submitted_by", "date", "verdict", "confidence", "pr_number"],
        "properties": {
          "issue_number": { "type": "integer" },
          "type": { "type": "string" },
          "submitted_by": { "type": "string" },
          "date": { "type": "string", "format": "date" },
          "verdict": { "type": "string", "enum": ["CONFIRMED", "DISPUTED", "REJECTED"] },
          "confidence": { "type": "string", "enum": ["high", "medium", "low"] },
          "pr_number": { "type": "integer" }
        }
      }
    },
    "changelog": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["version", "date", "change", "submitted_by", "issue", "pr", "verified_by", "approved_by"],
        "properties": {
          "version": { "type": "string" },
          "date": { "type": "string", "format": "date" },
          "change": { "type": "string" },
          "submitted_by": { "type": "string" },
          "issue": { "type": "integer" },
          "pr": { "type": "integer" },
          "verified_by": { "type": "string" },
          "approved_by": { "type": "string" }
        }
      }
    }
  }
}
